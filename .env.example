# Server (production / PM2)
PORT="3000"
NODE_ENV="production"

# Zoho Mail SMTP for trusttechlimited.com custom domain
# Copy to .env and fill SMTP_PASS locally — never commit .env
# Enable SMTP in Zoho Mail → Settings → Mail Accounts → IMAP Access
# If smtppro.zoho.com fails, try SMTP_HOST="smtp.zoho.com" with port 465 (587 may be blocked on some networks)

SMTP_HOST="smtppro.zoho.com"
SMTP_PORT="465"
SMTP_USER="mhindi@trusttechlimited.com"
SMTP_PASS=""
SMTP_FROM="Royal Regime <mhindi@trusttechlimited.com>"
SMTP_TO="mhindi@trusttechlimited.com"
